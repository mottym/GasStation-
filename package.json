{
  "name": "gas-station-platform",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "lint:web": "npm run lint --workspace=apps/web",
    "db:types": "supabase gen types typescript --local > packages/shared-types/database.types.ts",
    "seed:users": "node scripts/seed-users.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0"
  }
}
